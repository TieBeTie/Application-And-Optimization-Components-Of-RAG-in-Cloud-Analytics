# --- rag_api (https://github.com/danny-avila/rag_api) ---
# Embeddings: для начала openai, для реальных экспериментов — huggingface + BAAI/bge-m3
EMBEDDINGS_PROVIDER=huggingface
EMBEDDINGS_MODEL=BAAI/bge-m3

# БД (должно совпадать с docker-compose.yml)
POSTGRES_DB=mydatabase
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
DB_HOST=db
DB_PORT=5432

# --- eval harness ---
# Answer generation inside NaiveRAG pipeline
RAG_GENERATOR_API_KEY=gsk_your_groq_key_here
RAG_GENERATOR_BASE_URL=https://api.groq.com/openai/v1
RAG_GENERATOR_MODEL=llama-3.3-70b-versatile

# Evaluation metrics: judge + faithfulness + groundedness
LLM_JUDGE_API_KEY=gsk_your_groq_key_here
LLM_JUDGE_BASE_URL=https://api.groq.com/openai/v1
LLM_JUDGE_MODEL=llama-3.3-70b-versatile

RAG_API_URL=http://localhost:8000
LIGHTRAG_API_URL=http://localhost:9621
TOP_K=5
N_JUDGE_RUNS=5
